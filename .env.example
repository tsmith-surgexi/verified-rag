# verified-rag runs with NO configuration out of the box (deterministic
# synthesizer, zero API keys). This file documents the OPTIONAL real-LLM mode.
# Copy to `.env` only if you want to swap in an OpenAI-compatible model.
#
# The guarantee is identical either way: whatever the model emits is still
# verified against the corpus before any citation is released.

# Turn on the LLM synthesizer (default: off → deterministic template synth).
# VERIFIED_RAG_LLM=1

# OpenAI-compatible endpoint (leave unset to use the default OpenAI base URL).
# VERIFIED_RAG_LLM_BASE_URL=http://localhost:8000/v1

# Model id.
# VERIFIED_RAG_LLM_MODEL=gpt-4o-mini

# API key (or set OPENAI_API_KEY). NEVER commit a real key.
# VERIFIED_RAG_LLM_API_KEY=sk-...
